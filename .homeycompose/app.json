      "method": "POST",
      "path": "/exportAll"
    },
    "exportApp": {
      "method": "POST",
      "path": "/exportApp"
    },
    "testSmb": {
      "method": "POST",
      "path": "/testSmb"
    },
    "testFTP": {
      "method": "POST",
      "path": "/testFTP"
    },
    "testWebdav": {
      "method": "POST",
      "path": "/testWebdav"
    }
